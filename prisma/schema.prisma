generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  avatar          String?
  phone           String?
  company         String?
  isActive        Boolean  @default(true)
  emailVerified   DateTime?
  stripeCustomerId String?
  notifyOrderUpdates    Boolean @default(true)
  notifyProductUpdates  Boolean @default(true)
  notifyPromotional     Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  subscriptions   Subscription[]
  sites           Site[]
  jobs            Job[]
  notifications  Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("general") // order, custom_order, invoice, subscription, site, job, payment, system
  title    String
  message  String
  link     String?
  priority String   @default("medium") // low, medium, high
  isRead   Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([userId, isRead])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String   @db.Text
  shortDesc     String?
  type          String   @default("plugin")
  images        Json?
  price         Int      @default(0) // Price in cents, 0 = free
  features      Json?
  freeDownloadUrl   String?
  proDownloadUrl   String?
  documentation String?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubId          String?  @unique
  stripePriceId        String?
  lemonCustomerId      String?
  lemonSubscriptionId  String?  @unique
  status               String   @default("active")
  plan                 String   @default("free")
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Site {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain      String
  apiKey      String   @unique
  wpApiKey    String?
  wpSiteUrl   String
  status      String   @default("disconnected")
  template    String   @default("news") // news, business, modern
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
}

model Job {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status      String   @default("pending")
  outputUrl   String?
  logs        String   @db.LongText
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String   @db.Text
  icon             String
  basicPrice       Int
  standardPrice    Int
  premiumPrice     Int
  basicFeatures    Json
  standardFeatures Json
  premiumFeatures  Json
  order            Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
}

model Order {
  id              String   @id @default(cuid())
  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  packageType     String?
  planType        String?
  clientName      String
  clientEmail     String
  clientPhone     String?
  message         String?  @db.Text
  status          String   @default("pending")
  paymentStatus   String   @default("unpaid")
  paymentMethod   String?
  amount          Int      @default(0)
  currency        String   @default("USD")
  downloadCount   Int      @default(0)
  downloadLimit   Int      @default(3)
  lastDownloadedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CustomOrder {
  id                 String   @id @default(cuid())
  clientName       String
  clientEmail      String
  clientPhone     String   @default("")
  projectName     String
  projectDescription String   @db.Text
  serviceType     String   @default("")
  totalAmount    Int
  advanceAmount  Int
  remainingAmount Int
  advancePaid    Boolean  @default(false)
  remainingPaid  Boolean  @default(false)
  status         String   @default("pending")
  notes          String?   @db.Text
  receiptSent    Boolean  @default(false)
  receiptSentAt  DateTime?
  bankAccountId  String?   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BankSettings {
  id          String   @id @default(cuid())
  bankName    String   @default("")
  accountName String   @default("")
  accountNumber String @default("")
  sortCode    String   @default("")
  iban        String   @default("")
  swift       String   @default("")
  bankAddress String   @default("")
  country     String   @default("")
  currency    String   @default("USD")
  instructions String  @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  category    String
  imageUrl    String
  description String?  @db.Text
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
