# Database Connection (PlanetScale / Aiven MySQL)
DATABASE_URL="mysql://username:password@host:port/dbname?sslaccept=strict"

# NextAuth Configuration
NEXTAUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
NEXTAUTH_URL="https://wpcodingpress.com"

# Application URL
NEXT_PUBLIC_APP_URL="https://wpcodingpress.com"

# Resend (Email) - Get from https://resend.com
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="WPCodingPress <noreply@wpcodingpress.com>"
SUPPORT_EMAIL="support@wpcodingpress.com"
ADMIN_EMAIL="mmrahmanbld@gmail.com"

# Webhook Secret for Gumroad Signature Verification
# Set this in Gumroad dashboard: Settings -> Advanced -> Webhooks
GUMROAD_WEBHOOK_SECRET="your_gumroad_webhook_secret"

# Gumroad Product Links for Web Development Service
# Create products on Gumroad for each plan/billing combination
GUMROAD_STARTER_MONTHLY_LINK="https://rahmanbld.gumroad.com/l/starter-monthly"
GUMROAD_STARTER_ANNUAL_LINK="https://rahmanbld.gumroad.com/l/starter-annual"
GUMROAD_COMPLETE_MONTHLY_LINK="https://rahmanbld.gumroad.com/l/complete-monthly"
GUMROAD_COMPLETE_ANNUAL_LINK="https://rahmanbld.gumroad.com/l/complete-annual"

# Admin Email - receives notifications for new onboarding submissions
NEXT_PUBLIC_ADMIN_EMAIL="mmrahmanbld@gmail.com"

# For encrypting sensitive data (hosting credentials) in the database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# Gumroad API (Production)
GUMROAD_PRODUCT_LINK="https://rahmanbld.gumroad.com/l/wpcodingpress"
GUMROAD_APP_ID="your_gumroad_app_id"
GUMROAD_APP_SECRET="your_gumroad_app_secret"
GUMROAD_ACCESS_TOKEN="your_gumroad_access_token"

# Testing Mode - bypasses payment for development
TESTING_MODE=true

# Stripe (Future - for payments)
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_key_here"

# Stripe Price IDs - Create in Stripe Dashboard
STRIPE_PRO_PRICE_ID="price_xxx"
STRIPE_ENTERPRISE_PRICE_ID="price_xxx"

# ─── Vercel Deployment Integration ───
# Get your token from https://vercel.com/account/tokens
VERCEL_TOKEN="your_vercel_api_token"
# Optional: only if using a Vercel team account
VERCEL_TEAM_ID=""
# The Vercel Project ID of your headless template (found in Settings → General)
VERCEL_TEMPLATE_PROJECT_ID="prj_xxxxxxxxxxxx"
# Set to false when you upgrade to Vercel Pro
VERCEL_FREE_TIER=true

# WordPress Webhook Secret (used to verify webhook signatures from WordPress)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WP_WEBHOOK_SECRET="your_webhook_secret"

# Queue Driver: "database" (default, no extra cost) or "bullmq" (future, requires Redis)
QUEUE_DRIVER="database"
# REDIS_URL="redis://..." # Uncomment when using BullMQ
